OPENAI_API_KEY=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
# Anthropic API 配置 (Claude-3.5-Sonnet 批改專家)
ANTHROPIC_API_KEY=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
# Google Gemini API 配置 (Gemini-1.5-Pro 仲裁代理)
# 重要：這是仲裁代理的核心配置，用於解決 GPT-4 和 Claude 的評分分歧
GEMINI_API_KEY=AIzaSyBP1jWj9AeY4Ab_H4CvSXyBhYVUS4_4Yt4
# Flask 應用程式配置
# ------------------------------------------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# 三代理人批改系統配置
# ------------------------------------------------------------------------------

# 批改流程配置
MAX_GRADING_ROUNDS=6                    # 最大批改輪次
GRADING_TIMEOUT=300                     # 批改超時時間 (秒)
ARBITRATION_THRESHOLD=5.0               # 啟動仲裁的分數差異門檻
CONSENSUS_WEIGHT_GPT4=0.5               # GPT-4 在共識決策中的權重
CONSENSUS_WEIGHT_CLAUDE=0.5             # Claude 在共識決策中的權重

# 安全檢查配置
SECURITY_CHECK_ENABLED=True             # 啟用安全檢查
SECURITY_RISK_THRESHOLD=20              # 風險分數門檻
PROMPT_INJECTION_PROTECTION=True       # 啟用提詞注入防護

# 檔案處理配置
MAX_FILE_SIZE=16                        # 最大檔案大小 (MB)
ALLOWED_EXTENSIONS=txt,pdf,docx         # 允許的檔案格式
UPLOAD_TIMEOUT=60                       # 檔案上傳超時時間 (秒)

# 日誌配置
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO                          # 日誌等級 (DEBUG, INFO, WARNING, ERROR)
LOG_FILE_PATH=./logs/grading_system.log # 日誌檔案路徑
LOG_MAX_SIZE=10                         # 日誌檔案最大大小 (MB)
LOG_BACKUP_COUNT=5                      # 保留的日誌備份數量

# 模型配置
# ------------------------------------------------------------------------------

# GPT-4 模型配置
GPT4_MODEL_NAME=gpt-4o                  # GPT-4 模型名稱
GPT4_MAX_TOKENS=3000                    # GPT-4 最大輸出 tokens
GPT4_TEMPERATURE=0.0                    # GPT-4 溫度參數 (創造性控制)

# Claude 模型配置
CLAUDE_MODEL_NAME=claude-3-7-sonnet     # Claude 模型名稱
CLAUDE_MAX_TOKENS=3000                  # Claude 最大輸出 tokens
CLAUDE_TEMPERATURE=0.0                  # Claude 溫度參數

# Gemini 模型配置
GEMINI_MODEL_NAME=gemini-2.5-pro        # Gemini 模型名稱
GEMINI_MAX_TOKENS=7000                  # Gemini 最大輸出 tokens (仲裁用)
GEMINI_TEMPERATURE=0.0                  # Gemini 溫度參數 (最低，確保客觀性)

# 系統效能配置
# ------------------------------------------------------------------------------
REQUEST_TIMEOUT=120                     # API 請求超時時間 (秒)
RETRY_ATTEMPTS=3                        # API 失敗重試次數
RETRY_DELAY=2                           # 重試間隔時間 (秒)
RATE_LIMIT_DELAY=1                      # API 請求間隔 (秒)

# 快取配置
ENABLE_RESULT_CACHE=True                # 啟用結果快取
CACHE_EXPIRY_HOURS=24                   # 快取有效期 (小時)

MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=grading_blackboard

SECURITY_CHECK_ENABLED=True
SECURITY_RISK_THRESHOLD=20
PROMPT_INJECTION_PROTECTION=True

UNIFY_TABLE_STYLE=True

# 僅保留這兩個（不要再設 EMBEDDING_PROVIDER）
EMBEDDING_MODEL_NAME=models/text-embedding-004
SIM_USE_ONLY_EMBEDDING=true
SCORE_GAP_RATIO=0.30



# 題目拆分：支援 Q1:、第1題、Question 1 等字樣
QUESTION_SPLIT_HINT=^\s*(?:Q|第|Question|Problem|Task|Quiz|Exercise)\s*(\d{1,3})\s*(?:題)?\s*(?:[).。]|：|:|、|-)?
# 題目配分提示
QUESTION_SCORE_HINT=(?:配分|分值|分數|Points?)\s*[:：]?\s*(\d+(?:\.\d+)?)\s*分?



#SIMILARITY_THRESHOLD=0.78   # 建議 0.78~0.85；越高越嚴格
#EMBEDDING_MODEL_NAME=text-embedding-3-small


# 外部安全檢查代理
SECURITY_AGENT_ENABLED=true
SECURITY_AGENT_MUST_PASS=true

SECURITY_FORCE_FULL_LEARNING=1